def vernam_encode(nums, secret, offset=0):
    if len(secret) < len(nums) + offset:
        raise click.ClickException("Secret is too short!")

    return [n ^ ord(s) for n, s in zip(nums, secret[offset:])]

class IssueStatus(IntEnum):
    NO_ISSUE = 1
    BAD_TITLE = 2
    ISSUE_CLOSED = 3
    NO_URL = 4
    WRONG_URL = 5
    PAGE_404 = 6
    MISSING_SOURCE = 7
    MISSING_FILES = 8
    MISSING_AI = 9
    OK = 10
    
    @property
    def ok(self):
        return self == IssueStatus.OK


class Issue(object):
    def __init__(self, title, number, html_url, body, state, opened_by):
        self.title = title
        self.number = number
        self.html_url = html_url
        self.body = body
        self.state = state
        self.opened_by = opened_by

        self._labels = None
        self._comments = None
        self._status = None
        self._status_message = None
        self._fix_advice = None
        self._owner = None

        self._title_match = re.match(self.TITLE_REGEX, self.title)
        
        self._branch_confirmed = False
        self._default_branch = "main"

    TITLE_REGEX = r'STA +9750 +(\S*) +[Mm]ini-?[Pp]roject #\*{,2}?0(\d)\*{,2}'

    def to_json(self):
        return json.dumps({
            "number": self.number,
            "title": self.title,
            "opened_by": self.opened_by,
            "html_url": self.html_url, 
            "state": self.state,
            "body": self.body, 
            "labels": self.labels, 
            "comments": [c.to_dict() for c in self.comments],
            "status": self.status.name
        }, indent=4)
        
    @classmethod
    def from_gh_api_resp(cls, r):
        return cls(
            title=r["title"],
            number=r["number"],
            html_url=r["html_url"],
            body=r["body"],
            state=r["state"],
            opened_by=r["user"]["login"]
        )
        
    @classmethod
    def from_gh_api(cls, issue_num):
        r = _gh(f"/repos/{course_owner()}/{course_repo()}/issues/{issue_num}")
        
        return cls.from_gh_api_resp(r)
        
    @cached_property
    def mp_num(self):
        try: 
            return int(self._title_match.group(2))
        except: 
            import pdb; pdb.set_trace()
            
            return None
        
    @property
    def expected_title(self):
        return f"STA 9750 {self.owner} MiniProject #{self.mp_num:02}"
    
    @property
    def title_ok(self):
        if not self._title_match:
            return False
        if possible_owner := self._title_match.group(1):
            if self.opened_by == "michaelweylandt":
                return True
            return possible_owner.lower() == self.opened_by.lower()
        return False
        
    
    @property
    def expected_url(self):
        submission_text = mp_submission_instructions(self.mp_num).\
                            replace("YOUR_GITHUB_ID", self.owner)

        EXPECTED_URL = re.search(URL_REGEX, submission_text, re.IGNORECASE)
        
        return EXPECTED_URL.group(0)
        
    @property
    def owner(self):
        if self._owner is not None:
            return self._owner
        
        if match := self._title_match:
            if self.opened_by == "michaelweylandt" and match.group(1).lower() != "michaelweylandt":
                self._owner = match.group(1).lower()
            elif match.group(1).lower() == self.opened_by.lower():
                self._owner = match.group(1).lower()
            elif match.group(1) == "YOUR_GITHUB_ID":
                self._owner = self.opened_by.lower()
            else: 
                click.echo(f"Issue parsing title {self.title} for issue {self.number}")
                if click.confirm(f"Issue {self.number} ('{self.title}') opened by {self.opened_by}. Use {self.opened_by} as owner?"):
                    self._owner = self.opened_by.lower()
        elif self.opened_by != "michaelweylandt":
                self._owner = self.opened_by.lower()
        else:
            import pdb; pdb.set_trace()
                
        return self._owner

    def confirm_default_branch(self):
        available_branches = [b["name"] for b in _gh(f"repos/{self.opened_by}/{course_repo()}/branches")]
        if self._default_branch not in available_branches:
            self._default_branch = available_branches[0]
            
        self._branch_confirmed = True
        return self._default_branch
    
    @property
    def branch(self):
        if not self._branch_confirmed:
            return self.confirm_default_branch()
    
        return self._default_branch
        
    @property
    def submission_source(self):
        if self.mp_num == 0:
            return f"https://raw.githubusercontent.com/{self.owner}/{course_repo()}/refs/heads/{self._default_branch}/index.qmd"
        else: 
            return f"https://raw.githubusercontent.com/{self.owner}/{course_repo()}/refs/heads/{self._default_branch}/mp{self.mp_num:02}.qmd"

    @property
    def status(self):
        if self._status is not None :
            return self._status

        if self.mp_num is None:
            self._status = IssueStatus.BAD_TITLE
            self._status_message = f"Could not parse title {self.title}"
            return self._status

        if not self.title_ok:
            self._status = IssueStatus.BAD_TITLE
            self._status_message = dedent(f"""\
            Expected title: {self.expected_title}
            Actual title:   {self.title}""")
            self._fix_advice = dedent("""\
            Note that you can change the title of this issue to fix this
            problem by hitting the 'Edit' button to the right of the current title
            at the top of this page. You do not need to open a new issue.""")
            return self._status

        if self.state != "open":
            self._status = IssueStatus.ISSUE_CLOSED
            return self._status

        submission_text = mp_submission_instructions(self.mp_num).\
                            replace("YOUR_GITHUB_ID", self.owner)

        STUDENTS_URL = re.search(URL_REGEX, self.body, re.IGNORECASE)

        if STUDENTS_URL is None:
            self._status = IssueStatus.NO_URL
            self._fix_advice = dedent("""\
            You can modify your post by scrolling up to your original post and
            clicking the three dots button at the top right of your post. Select
            "Edit" and you can edit the text of your post. You do not need to
            open a new issue to resolve this issue.
            """)
            return self._status
        else:
            STUDENTS_URL = STUDENTS_URL.group(0)
        
        if STUDENTS_URL.lower() != self.expected_url.lower():
            self._status = IssueStatus.WRONG_URL
            self._status_message = f"Expected URL: {self.expected_url}\nSubmitted URL: {STUDENTS_URL}"
            self._fix_advice = dedent("""\
            You can modify your post by scrolling up to your original post and
            clicking the three dots button at the top right of your post. Select
            "Edit" and you can edit the text of your post. You do not need to
            open a new issue to resolve this issue.
            """)
            return self._status
        
        page_resp = r.get(self.expected_url)
        
        if not page_resp.ok: 
            self._status = IssueStatus.PAGE_404
            self._status_message = f"Accessing {STUDENTS_URL} returns HTTP code {page_resp.status_code}"
            return self._status
        
        source_ok = r.get(self.submission_source).ok
        
        if not source_ok:
            self.confirm_default_branch()
            source_ok = r.get(self.submission_source).ok
        
        if not source_ok:
            self._status = IssueStatus.MISSING_SOURCE
            self._status_message = f"Expected source file not found at: {self.submission_source}"
            self._fix_advice = dedent(f"""\
            Typically, this means you need to:
                
                1) `git add` the missing file `{op.basename(self.submission_source)}`
                   (or check the corresponding box in `RStudio`'s `Git` pane), 
                2) make a new  git commit and 
                3) push that commit to GitHub. 
                
            You do not need to open a new issue to resolve this issue.""")
            return self._status

        support_file_check_results = check_quarto_support_files(STUDENTS_URL)

        if support_file_check_results["fail"]:
            self._status = IssueStatus.MISSING_FILES
            self._status_message = "Could not access the following files:\n - " + "\n - ".join(support_file_check_results["fail"])
            
            self._status_message += dedent("""
            Please make sure to `git add` the corresponding files from your
            `docs` repository. Once you have done this, make a new commit and
            `git push` to update your GitHub repository. You do not need to open
            a new issue or re-post here (though adding a new comment won't hurt)
            - simply pushing the updated and corrected files will automatically 
            propogate through to this issue thread.""")

            return self._status
        
        page_bs =  BS(page_resp.text, features="lxml")
        ai_disclosure = page_bs.find_all(class_="callout-note")

        if not ai_disclosure:
            self._status = IssueStatus.MISSING_AI
            self._status_message = "Could not locate your AI Usage Statement - No '.callout-note' block."
            
            self._fix_advice = dedent("""
            See MP instructions for how to use a suitable block for AI Usage 
            Statement. Please update your qmd file, re-render the 
            document, and `git push` to update your GitHub repository. You 
            do not need to open a new issue or re-post here (though adding a
            new comment won't hurt) - simply pushing the updated and 
            corrected files will automatically propogate through to this 
            issue thread.""")
            return self._status
        
        if len(ai_disclosure) > 1:
            if sum("AI" in ai.get_text() for ai in ai_disclosure):
                ai_disclosure = [ai for ai in ai_disclosure if "AI" in ai.get_text()][-1]
            else:
                import pdb; pdb.set_trace()
        else:
            ai_disclosure = ai_disclosure[-1]
        
        if "title" in ai_disclosure.attrs:
            ai_title = ai_disclosure["title"]
        elif ai_title_container := ai_disclosure.find(class_="callout-title-container"): 
            ai_title = ai_title_container.find_all(string=True, recursive=False)
            ai_title = "".join(ai_title).strip()
        else: 
            import pdb; pdb.set_trace()
            
        if ai_title != "AI Usage Statement":
            self._status = IssueStatus.MISSING_AI
            self._status_message = "Could not locate your AI Usage Statement - '.callout-note' block title incorrect."
            self._fix_advice = dedent(f"""
            No '.callout-note' with title 'AI Usage Statement' identified,
            though I did find one with the title '{ai_title}' instead. If this 
            is your AI Usage Statement, please update your qmd file, re-render 
            the document, and `git push` to update your GitHub repository. You 
            do not need to open a new issue or re-post here (though adding a
            new comment won't hurt) - simply pushing the updated and 
            corrected files will automatically propogate through to this 
            issue thread.""")
            return self._status

        
        self._status = IssueStatus.OK
        
        return self._status
    
    @property 
    def fix_advice(self):
        if not self._fix_advice:
            _ = self.status
        return self._fix_advice
    
    @property
    def status_oneline(self):
        status = self.status
        
        if status == IssueStatus.BAD_TITLE:
            return f"Could not parse issue title"
        elif status == IssueStatus.ISSUE_CLOSED:
            return f"Issue appears closed"
        elif status == IssueStatus.NO_URL:
            return f"No URL submitted"
        elif status == IssueStatus.WRONG_URL:
            return f"Incorrect URL submitted"
        elif status == IssueStatus.PAGE_404:
            return f"Page fails to load: " + self._status_message
        elif status == IssueStatus.MISSING_SOURCE:
            return f"Could not identify qmd source document\n - " + self._status_message
        elif status == IssueStatus.MISSING_FILES:
            return self._status_message
        elif status == IssueStatus.MISSING_AI:
            return self._status_message
        elif status == IssueStatus.OK:
            return "OK"
        else:
            raise click.ClickException("Unknown status")
        
    @property
    def status_full(self):
        CHECKS = ["Issue Identified", 
                  "Correct Issue Title", 
                  "Correct Issue Status (Open)",
                  "Submission URL Present",
                  "Submission URL Correct", 
                  "Submission URL Accessible",
                  "Source File Accessible",
                  "All Supporting Files Present",
                  "AI Disclosure Present",]
                  
        OUT_TEXT = ""
                  
        assert len(CHECKS) + 1 == IssueStatus.OK # +1 b/c top status is OK (no check)
        
        for check_ix, check_text in enumerate(CHECKS, start=1):
            if self.status > check_ix:
                OUT_TEXT += "- [✅] "+  check_text + "\n"
            elif self.status == check_ix:
                OUT_TEXT += "- [❌] "+  check_text+ "\n"
            else:
                OUT_TEXT += "- [ ] "+  check_text + "\n"
                
        if self._status_message: 
            OUT_TEXT += "\n" + self._status_message 
            
        return OUT_TEXT 
    
    @property
    def ok(self):
        return self.status == IssueStatus.OK
    
    @property
    def is_open(self):
        return self.state == "open"
    
    @property
    def already_passed(self):
        return "Passed Automated Checks" in self.labels
    
    @property
    def comments(self):
        if not self._comments:
            self._comments = gh_list_comments(self.number)
        return self._comments
    
    @property 
    def labels(self):
        if self._labels is None:
            resp = _gh(f"/repos/{course_owner()}/{course_repo()}/issues/{self.number}/labels")
            
            self._labels = [l["name"] for l in resp]
            self._labels.sort()

        return self._labels
            
    def add_label(self, label):
        available_labels = gh_available_labels()
        
        if label not in available_labels:
            raise click.ClickException(f"Unsupported label - {label}")
        
        if self._labels is not None and label in self._labels:
            return
        
        _gh(f"repos/{course_owner()}/{course_repo()}/issues/{self.number}/labels", 
            method="post",
            labels=tuple([label]))
            
        # Reset cached value
        self._labels = None
            
    def remove_label(self, label):
        available_labels = gh_available_labels()
        
        if label not in available_labels:
            raise click.ClickException(f"Unsupported label - {label}")
        
        if label not in self.labels:
            return
        
        _gh(f"repos/{course_owner()}/{course_repo()}/issues/{self.number}/labels/{label}", 
            method="delete")
            
        # Reset cached values
        self._labels = None
        
    def close(self):
        if self.state == "closed":
            return
        
        r = _gh(f"repos/{course_owner()}/{course_repo()}/issues/{self.number}", 
                method="patch", 
                state="closed", 
                state_reason="completed")
                
        if not r.ok:
            raise click.ClickException(f"GitHub problem closing issue {self.issue_num}")
        
        self.state = "closed"
    
    def update_labels_submission_checks(self):
        available_labels = gh_available_labels()
        new_labels = []
        
        if self.status == IssueStatus.OK:
            new_labels.append("Passed Automated Checks")
            self.remove_label("Failed Automated Checks")
        else: 
            new_labels.append("Failed Automated Checks")
            self.remove_label("Passed Automated Checks")
            
        if self.mp_num is not None:
            new_labels.append(f"Mini-Project #0{self.mp_num}")
            
        # FIXME: Check whether PF has been assigned for this issue
        new_labels.append("Awaiting Peer Feedback Assignment")
            
        new_labels.sort()
        
        if any(nl not in available_labels for nl in new_labels):
            import pdb; pdb.set_trace()
            
        if new_labels != self.labels:
            click.echo(f"Updating Labels on Issue #{self.number} to {new_labels}")
            
            _gh(f"repos/{course_owner()}/{course_repo()}/issues/{self.number}/labels", 
                method="put",
                ## FIXME: Why is tuple required here? Without it I get a
                ## TypeError because new_labels is unhashable, but this is the
                ## value, not the key, so who cares?
                labels=tuple(new_labels))
        else:
            click.echo(f"Leaving labels unchanged: {self.labels}")
    
    def post_new_comment(self, text):
        text = "\n".join(t.rstrip() for t in text.split("\n"))

        if self.comments and (self.comments[-1].text == text):
            return # No need to double post if verbatim match!
        
        _gh(f"/repos/{course_owner()}/{course_repo()}/issues/{self.number}/comments",
            method="post",
            body=text)
            
        self._comments = None
        
    def __repr__(self):
        return f'Issue #{self.number:02} - {self.title}'
        
class IssueCollection(object):
    def __init__(self):
        click.echo("Acquiring all GitHub issues")
        ALL_ISSUES = []
        pagination = 1
    
        while((len(ALL_ISSUES) % 100) == 0): 
            resp = _gh(f"/repos/{course_owner()}/{course_repo()}/issues?state=all&per_page=100&page={pagination}")

            if not resp: 
                break

            if "status" in resp and resp["status"] != "200":
                import pdb; pdb.set_trace()
                raise click.ClickException("UNABLE TO ACCESS GITHUB API")
        
            ALL_ISSUES += resp
            pagination += 1
            
        self._issues = [None] * len(resp)
        
        for ix, r in enumerate(resp):
            self._issues[ix] = Issue.from_gh_api_resp(r)
            
        self._issues.sort(key=lambda x: x.number)
        click.echo("Issue import complete")
            
    def select_by_owner(self, owner):
        return [i for i in self._issues if owner.lower() == i.owner]
    
    def select_unknown_mp(self):
        return [i for i in self._issues if i.mp_num is None]
    
    def select_mp_or_unknown(self, mp_num, ask=True):
        known = [i for i in self._issues if i.mp_num == mp_num]
        unknown = self.select_unknown_mp()
        
        for u in unknown: 
            click.echo(f"Issue #{u.number:03} ({u.title}) was opened by {u.opened_by}.")
            
            if ask:     
                if click.confirm("Should this issue be considered as part of MP#{mp_num:02}?", default=False):
                    known.append(u)
                else: 
                    click.echo(f"Omitting Issue #{u.number:03} ({u.title}) from processing.")
            else:
                known.append(u) # Silently keep for later processing
            
        owners = [k.owner for k in known]
        repeated_owners = [o for o in owners if owners.count(o) >= 2]
        
        for ro in repeated_owners:
            ro_issues = [k for k in known if k.owner == ro]
            # If only one passes checks, let's use this one
            if sum(i.ok for i in ro_issues) == 1:
                for i in ro_issues:
                    if not i.ok:
                        known.remove(i)
            # If only one issue is open, let's use that one
            elif sum(i.is_open for i in ro_issues) == 1:
                for i in ro_issues:
                    if not i.is_open:
                        known.remove(i)
            else:
                import pdb; pdb.set_trace()    

        return known
    
    def __getitem__(self, issue_number):
        matches = [i for i in self._issues if i.number == issue_number]
        
        if matches:
            return matches[0]
        else:
            raise IndexError
    
    def __len__(self):
        return len(self._issues)
    
    def __iter__(self):
        return self._issues.__iter__()
                     
