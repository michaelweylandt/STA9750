    for row in TEAM.itertuples():
        click.echo(
            f"{row.name} (GH: {row.github}; EMAIL: {row.email}) - {row.team_name}"
        )

    feedback_dir = op.join(course_dir(), element.lower())
    os.makedirs(feedback_dir, exist_ok=True)

