@cache
def check_quarto_support_files(url):
    """Check if any helper files are missing from a Quarto website
    
    This check only goes one level deep and does not check URLs outside the
    domain of the base url."""
    
    resp = r.get(url)
    
    if not resp.ok:
        raise click.ClickException(f"Could not access {url} to check support files")
    
    url_base = op.dirname(url)
    
    soup = BS(resp.text, features="lxml")
    
    LINKS_CHECKED = []
    LINKS_OK = []
    LINKS_FAIL = []

    support_links = [urljoin(url, sf["href"]) for sf in soup.find_all("link") if not sf["href"].startswith("http")]
    image_links = [urljoin(url, sf["src"]) for sf in soup.find_all("img") if not sf["src"].startswith("http")]
    anchor_links = [urljoin(url, sf["href"]) for sf in soup.find_all("a") if not sf["href"].startswith("http")]
    
    # Dedup multiple links on the same page
    anchor_links = set(a.split("#")[0] for a in anchor_links)
    
    for sf_url in chain(support_links, image_links, anchor_links):
        LINKS_CHECKED.append(sf_url)
        
        # Skip embedded elements
        if sf_url.startswith("data:") or sf_url.startswith("javascript:"):
            LINKS_OK.append(sf_url)
            continue 
        
        if r.get(sf_url).ok:
            LINKS_OK.append(sf_url)
        else: 
            LINKS_FAIL.append(sf_url)
        
    return {"all": LINKS_CHECKED, 
            "ok": LINKS_OK, 
            "fail": LINKS_FAIL}
    
    
