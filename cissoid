@peer.command(name="assign")
@click.option(
    "-N",
    "--number",
    "project_id",
    prompt="Which mini-project to archive?",
    type=click.IntRange(min=0, max=4),
)
@click.option(
    "--dry-run", "dry_run", help="Skip posting to GitHub", default=False, is_flag=True
)
@click.option(
    "--skip-archive",
    "skip_archive",
    help="Skip archiving student submissions",
    default=False,
    is_flag=True,
)
@click.option(
    "-P",
    "--peer-count",
    help="How many peers to assign per submission",
    prompt="How many peers should be assigned for each submission?",
    type=click.IntRange(min=1, max=5),
)
@click.option(
    "-s",
    "--github-skip",
    multiple=True,
    help="GitHub ID to skip submission. This is used when students have a pre-approved extension.",
)
@click.option(
    "--no-lint", 
    "lint",
    default=True, 
    is_flag=True,
    help="Skip linting student submissions"
)
def peer_assign(project_id, peer_count, dry_run, skip_archive, github_skip, lint):
    """Assign Mini-Project Peer Feedback

    This command does several things:

    0) It archives all submissions for that MP
    1) It creates a mapping from submitters to peer reviewers.
       Since I'm now doing assignment only among students who submitted,
       this mapping must be created randomly each time. 
    2) It creates an encoded file that can be posted to the course GitHub
       repo with peer feedback assignments. 
    3) It opens a page to post the encoded file automatically 
    4) It lints student submissions [TODO]
    5) It posts notifications comments and lint output to GitHub. [TODO]

    Note that this command should only be used once per assignment.
    """
    
    PF_DIR = op.join(course_dir(), f"mp{project_id:02}")
    os.makedirs(PF_DIR, exist_ok=True)
    
    PF_MAPPING_FILE = _peer_feedback_mapping_file(project_id)
    PF_STUDENT_FILE = _peer_feedback_student_file(project_id)
    
    if not skip_archive:
        _mini_archive(project_id, [])
        
    if False: # TODO: Implement linting
        lint_result_dir = mini_lint(project_id)
        
    ROSTER = current_roster(include_inactive=False)
        
    ## First thing, let's load the relevant issues and identify 
    ## those for this MP only
    ISSUES = IssueCollection().select_mp_or_unknown(project_id, ask=True)
    
    with click.progressbar(ISSUES, length = len(ISSUES), 
                           show_pos=True,
                           label="Checking Submissions",
                           item_show_func=lambda r: r.owner if r else None) as bar:
        for i in bar:
            i.status # Do this just to pre-calculate statuses
    
    ISSUES_DF = pd.DataFrame([(i.number, i.owner, i.ok, i.status_oneline, i.branch) for i in ISSUES], 
                        columns=["number", "owner", "ok", "status_oneline", "branch"])
    
    actual_submittors = [i.owner.lower() for i in ISSUES]
    
    if any(actual_submittors.count(x) >= 2 for x in actual_submittors):
        import pdb; pdb.set_trace()
        
    expected_submittors = set(g.lower() for g in ROSTER.github)
    
    for a in actual_submittors:
        if a not in expected_submittors:
            raise click.ClickException(f"Unknown submission received - {a}")
        
    refresh_issues = False
        
    for e in expected_submittors:
        if e not in actual_submittors and e not in github_skip:
            e_real_name = ROSTER[ROSTER.github.map(str.lower) == e].name.item()
            if click.prompt(f"No submission received for {e} ({e_real_name}) - did they submit on Brightspace?", default=True, type=bool):
                if _possible_open_instructor_issue(e, project_id):
                    actual_submittors.append(e)
                    refresh_issues = True
            else: 
                click.echo(f"Not opening an issue on behalf of {e}.")
                
    
    if refresh_issues:
        ISSUES = IssueCollection().select_mp_or_unknown(project_id, ask=True)
        
        with click.progressbar(ISSUES, length = len(ISSUES), 
                           show_pos=True,
                           label="Re-checking Submissions",
                           item_show_func=lambda r: r.owner if r else None) as bar:
            for i in bar:
                i.status # Do this just to pre-calculate statuses
    
    ISSUES_DF = pd.DataFrame([(i.number, i.owner, i.ok, i.status_oneline, i.branch) for i in ISSUES], 
                        columns=["number", "owner", "ok", "status_oneline", "branch"])
    
    if len(actual_submittors) < 2 * peer_count:
        raise click.ClickException("Too many peers required for given submission pool.")
    
    random.shuffle(actual_submittors)
    n_submittors = len(actual_submittors)
        
    if op.exists(PF_MAPPING_FILE) and op.getsize(PF_MAPPING_FILE):
        click.echo(f"Using existing mapping file from {PF_MAPPING_FILE}.")
    else:
        PEER_REVIEW_MAPPING = {}
        
        for ix, a in enumerate(actual_submittors): 
            to_review = []
            for offset in range(1, peer_count + 1):
                to_review.append(actual_submittors[(ix + offset) % n_submittors])
            
            PEER_REVIEW_MAPPING[a] = to_review

        with open(PF_MAPPING_FILE, "w") as f:
            f.write(json.dumps(PEER_REVIEW_MAPPING, indent=4))
            
    with open(PF_MAPPING_FILE) as f:
        PEER_REVIEW_MAPPING = json.loads(f.read())
        
    if op.exists(PF_STUDENT_FILE) and op.getsize(PF_STUDENT_FILE):
        click.echo(f"Using existing student file from {PF_STUDENT_FILE}.")
    else:
        YAML_OUT = {
            "mp_number": project_id,
            "number_of_peers": peer_count, 
            "number_of_submissions": n_submittors, 
            "assignments": {}, 
            "issue_status": ISSUES_DF.to_dict(orient="records")
        }
        
        for student in ROSTER.itertuples():
            if student.github.lower() not in actual_submittors:
                continue
        
            # Get assigned issue numbers
            to_review = PEER_REVIEW_MAPPING[student.github.lower()]
            assigned_issues = sorted([i.number for i in ISSUES if i.owner in to_review])
    
            # Encode using a Vernam cipher
            vernam_code = vernam_encode(assigned_issues, student.secret, offset=project_id)
            assert assigned_issues == vernam_encode(vernam_code, student.secret, offset=project_id)
            
            YAML_OUT["assignments"][student.github.lower()] = vernam_code
        
        with open(PF_STUDENT_FILE, "w") as f:
            f.write(yaml_dump(YAML_OUT, sort_keys=False))
    
        click.echo(f"Student peer feedback assignment file saved to {PF_STUDENT_FILE}")
        
    click.echo(f"If not already done, please upload {PF_STUDENT_FILE} to GitHub at https://github.com/{course_owner()}/{course_repo()} as 'pf_mp{project_id:02}.yaml' and announce assignment to students")
    
    with open(PF_STUDENT_FILE, "r") as f:
        f_txt = f.read()
    
    PF_STUDENT_URL = f"https://raw.githubusercontent.com/{course_owner()}/{course_repo()}/refs/heads/main/pf_mp{project_id:02}.yaml"
    
    if not r.get(PF_STUDENT_URL).ok:
        webbrowser.open(f"https://github.com/{course_owner()}/{course_repo()}/new/main?filename=pf_mp{project_id:02}.yaml&value={quote_plus(f_txt)}")
    
    if dry_run: 
        return 0
    
    template = Environment(
            loader=FileSystemLoader("_cissoid/templates"), 
            autoescape=select_autoescape()
                            ).get_template("pf_assigned_gh_comment.md")
        
    with click.progressbar(ISSUES, length=len(ISSUES), 
                           show_pos=True,
                           label="Updating Labels and Posting Notification Comments",
                           item_show_func=lambda r: r.owner if r else None) as bar:
        # TODO: Comments to submittors? Update issue labels?
        for issue in bar:
            text_md = template.render(
                gh = issue.owner,
                project_id = project_id, 
                n_assignments=peer_count
            )
        
            issue.post_new_comment(text_md)
        
            issue.remove_label('Awaiting Peer Feedback Assignment')
            issue.add_label('Peer Feedback Period')

