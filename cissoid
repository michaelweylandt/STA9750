def mini_verify(project_id, github, dry_run, force):
    """Verify that a mini-project was submitted and formatted correctly

    This script can be used to verify correct submission of mini-projects and,
    if necessary, to highlight possible issues. This function does _not_ provide
    feedback for students and is primarily intended for instructor use.

    To process submissions after the deadline passes, use the `process` command
    instead."""
    return _mini_verify(project_id, github, dry_run, force)

def _get_submission_urls(project_id, github, check_master=True):
    MP_URL = f"{course_site()}/mini/mini0{project_id}.html"

    MP_PAGE = r.get(MP_URL)
    MP_TEXT = (
        BS(MP_PAGE.text, features="lxml").find(id="submission-text").get_text().strip()
    )
    BODY = MP_TEXT.replace("YOUR_GITHUB_ID", github)
    EXPECTED_URL = re.search(URL_REGEX, BODY).group()

    if project_id:
        RAW_URL = f"https://raw.githubusercontent.com/{github}/{course_repo()}/refs/heads/main/mp{project_id:02}.qmd"
    else:
        RAW_URL = f"https://raw.githubusercontent.com/{github}/{course_repo()}/refs/heads/main/index.qmd"

    if check_master and not r.get(RAW_URL).ok:
        RAW_URL_MASTER = RAW_URL.replace("main", "master")
        if r.get(RAW_URL_MASTER).ok:
            return (EXPECTED_URL, RAW_URL_MASTER)

    return (EXPECTED_URL, RAW_URL)


def _mini_verify(project_id, github, dry_run=True, force=False):
    "Implementation of mini_verify. Can be called directly by other functions"
    MP_URL = f"{course_site()}/mini/mini0{project_id}.html"

    MP_PAGE = r.get(MP_URL)
    MP_TEXT = BS(MP_PAGE.text, features="lxml").\
                  find(id="submission-text").get_text().strip()

    if not github:
        github = current_roster().github.values

    RESULTS = {g: None for g in github}
    
    ISSUES = IssueCollection()

    for gh in github:
        click.echo("-----------------------------------")
        click.echo(f"Attempting to verify for user {gh}...", nl=False)
        TITLE = f"{course_short()} {gh} MiniProject #0{project_id}"
        BODY = MP_TEXT.replace("YOUR_GITHUB_ID", gh)

        gh_issues = ISSUES.select_by_owner(gh)
        
        gh_issues = [i for i in gh_issues if i.mp_num == project_id or i.mp_num is None]
        
        if not gh_issues:
            import pdb; pdb.set_trace()
            click.echo(f"No issues found for user {gh} in repo {course_repo()}")
            RESULTS[gh] = (False, gh, IssueStatus.NO_ISSUE, "NO ISSUES FOUND", None)
            continue
        if len(gh_issues) > 1:
            open_issues = [g for g in gh_issues if g.state == "open"]
            
            if len(open_issues) == 1:
                gh_issues = open_issues
            else:
                import pdb; pdb.set_trace()

        gh_issue = gh_issues[0]
        
        if not force and gh_issue.already_passed: 
            RESULTS[gh] = (True, gh, IssueStatus.OK, "OK", gh_issue.number)
        
        gh_issue_status = gh_issue.status
        
        RESULTS[gh] = (gh_issue_status.ok, gh, gh_issue.status, gh_issue.status_oneline, gh_issue.number)
        
        if gh_issue_status.ok:
            click.echo(f"All checks passed for {gh}")
        else:
            click.echo(f"Check failed for {gh} - {gh_issue.status.name}")
            if gh_issue._status_message:
                click.echo(gh_issue._status_message)
        
        if not dry_run:
            gh_issue.update_labels_submission_checks()
        
    DF = pd.DataFrame(RESULTS).T
    DF.columns = ["ok", "github", "status", "message", "issue_num"]

    click.echo("-----------------------------------")
    click.echo("----------ANALYSIS COMPLETE--------")

    github_ok = sorted(DF[DF.ok].github.values, key=str.casefold)
    n_ok = len(github_ok)

    if DF.ok.any():
        click.echo("-----------------------------------")
        click.echo(f"MP #{project_id:02g} successfully verified for {n_ok} students: ")
        for ix, g in enumerate(github_ok, start=1):
            click.echo(f"- {ix:02g} {g}")

    if not DF.ok.all():
        click.echo("-----------------------------------")
        
        DF_BAD = DF[DF.ok != True]
        DF_BAD = DF_BAD.sort_values("github", key=lambda col: col.str.lower())
        click.echo(f"Problems were identified for the following {DF_BAD.shape[0]} users:")

        for ix, row in enumerate(DF_BAD.itertuples(), start=n_ok+1):
            if row.issue_num:
                click.echo(
                    f"- {ix:02g} GitHub user {row.github} failed with status '{row.status.name}'.\n  See https://github.com/{course_owner()}/{course_repo()}/issues/{row.issue_num} for details"
                )
            else:
                click.echo(
                    f"- {ix:02g} GitHub user {row.github} failed with status {row.status.name}. No suitable issue found."
                )
                
    
    click.echo("-----------------------------------")
    click.echo("-------------END SUMMARY-----------")
    click.echo("-----------------------------------")
                
    if dry_run:
        return DF
    
    for issue_unknown_mp in ISSUES.select_unknown_mp():
        issue_comments = issue_unknown_mp.comments
        
        template = Environment(
            loader=FileSystemLoader("_cissoid/templates"), 
            autoescape=select_autoescape()
                            ).get_template("mp_title_parse_fail.md")
                            
        text_md = template.render(
            gh = issue_unknown_mp.owner,
            project_id = project_id, 
            current_title = issue_unknown_mp.title
        )
        
        if issue_comments and issue_comments[-1].text == text_md:
            continue
        else:
            issue_unknown_mp.post_new_comment(text_md)
            
    loader = Environment(loader=FileSystemLoader("_cissoid/templates"), 
                         autoescape=select_autoescape())

    with click.progressbar(DF.itertuples(), length = DF.shape[0], show_pos=True,
                           label="Posting GitHub Comments (if needed)",
                           item_show_func=lambda r: r.Index if r else None) as bar:        
        for issue_row in bar:
            if issue_row.issue_num is None:
                continue
            
            issue = ISSUES[issue_row.issue_num]
            
            if not force and issue.already_passed: 
                continue
            
            issue_comments = issue.comments
            
            if issue.mp_num is None:
                continue
            
            if issue.ok:
                template = loader.get_template("mp_all_checks_pass.md")
            else: 
                template = loader.get_template("mp_checks_fail.md")
                
            text_md = template.render(
                gh = issue.owner,
                project_id = project_id, 
                check_output = issue.status_full,
                fix_advice = issue.fix_advice
            )

            if issue_comments and issue_comments[-1].text == text_md:
                continue
            else:
                #click.echo(f"Posting new comment for {issue.owner}")
                issue.post_new_comment(text_md)
            
    return DF

def _possible_open_instructor_issue(github_id, project_id):
    click.echo("Opening HTML file")
    webbrowser.open(f"https://{github_id}.github.io/{course_repo()}/mp{project_id:02}.html")
    
    if not click.prompt("Was a working HTML file submitted?", type=bool, default=True):
        return False
    
    webbrowser.open(f"https://github.com/{github_id}/{course_repo()}/")
    
    if not click.prompt("Was a suitable qmd file submitted?", type=bool, default=True):
        return False
    
    if not click.prompt(f"Would you like to open an MP#{project_id:02} issue on behalf of {github_id}", default=True, type=bool):
        return False
    
    template = Environment(
            loader=FileSystemLoader("_cissoid/templates"), 
            autoescape=select_autoescape()
    ).get_template("mp_instructor_issue_opened.md")
    
    issue_text = template.render(gh = github_id, 
                                 project_id = project_id, 
                                 course_repo = course_repo())
    
    r = _gh(f"/repos/{course_owner()}/{course_repo()}/issues", 
            method="post", 
            title=f"{course_short()} {github_id} MiniProject #0{project_id}",
            body=issue_text)
            
    if r.ok:
        _mini_verify(project_id, github_id, dry_run=False)
        _mini_archive(project_id, github_id)
        
        return True
    else:
        import pdb; pdb.set_trace()
    
    

