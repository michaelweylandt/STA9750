def number_to_letter(score):
    if score >= 97:   # 97-100
        return "A+"
    elif score >= 93: # 94-97
        return "A"
    elif score >= 90: # 90-92
        return "A-"
    elif score >= 87: # 87-89 
        return "B+"
    elif score >= 83: # 83-86
        return "B"
    elif score >= 80: # 80-82
        return "B-"
    elif score >= 77: # 77-79
        return "C+"
    elif score >= 73: # 73-76
        return "C"
    elif score >= 70: # 70-72
        return "C-"
    elif score >= 67: # 67-69
        return "D+"
    elif score >= 63: # 63-66
        return "D"
    elif score >= 60: # 60-62
        return "D-"
    else:
        return "F"


