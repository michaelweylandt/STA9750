    "--github",
    help="If provided, only provide roster information for listed students",
    multiple=True,
)
@click.option(
    "-G",
   "grep_flag",
   help="If provided, grep all fields (case insensitive) to subset roster"
)
@click.option(
    "--EMAIL",
    "send_email",
    help="Send email to listed students",
    is_flag=True,
    default=False
)
def roster_list(include_inactive, include_emplid, include_secret, 
                github, grep_flag, send_email):
    """Print current course roster"""
    
    if github and grep_flag: 
        raise click.ClickException("Cannot pass -g and -G flags simultaneously")
    
    roster = current_roster(include_inactive=include_inactive)
    teams = current_teams(include_pending=False)

    if teams.size:
        full_roster = pd.merge(
            roster, 
            teams.rename(columns={
                "name": "team_name", 
                "number": "team_number"
            }),
            left_on="project_team", 
            right_on="team_number", how="left").\
        drop(["project_team", "team_number", "team_status"], axis=1)
    else:
        full_roster = roster
    
    full_roster.index = full_roster.index + 1
    
    if not include_emplid:
        full_roster = full_roster.drop(["emplid"], axis=1)
        
    if not include_inactive:
        full_roster = full_roster.drop(["active"], axis=1)
        
    if not include_secret:
        full_roster = full_roster.drop(["secret"], axis=1)
        
    full_roster = full_roster.rename(columns={
        "github": "GitHub ID", 
        "email": "Student Email", 
        "name": "Student Name", 
        "team_name": "Project Team Name", 
        "active": "Status",
        "emplid": "Student ID", 
        "secret": "Secret Code"
    })
    
    if github:
        full_roster = full_roster.loc[full_roster["GitHub ID"].isin(github),:]
        
    if grep_flag: 
        gh_re_flag = full_roster["GitHub ID"].str.contains(grep_flag, flags = re.IGNORECASE)
        nm_re_flag = full_roster["Student Name"].str.contains(grep_flag, flags = re.IGNORECASE)
        tm_re_flag = full_roster["Project Team Name"].str.contains(grep_flag, flags = re.IGNORECASE)
        
        all_re_flag = gh_re_flag | nm_re_flag | tm_re_flag
        
        full_roster = full_roster.loc[all_re_flag,:]
    
    if github or grep_flag: 
        list_str = "match search"
    else: 
        list_str = "registered"
    
    if send_email:
        open_email(
            subject=f"STA 9750 ",
            to=full_roster["Student Email"].to_list(),
        )
    else:
        click.echo(full_roster.to_markdown(index=True))

        if include_inactive:
            click.echo(f"{full_roster.shape[0]} total students {list_str} (including inactive).")
        else: 
            click.echo(f"{full_roster.shape[0]} active students {list_str}.")

